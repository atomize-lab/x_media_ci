# Optional environment overrides for x_media CI tools.
# Copy this file to `.env` and edit; the values are read via os.environ.

# Tesseract binary. If unset, the OCR scripts will look for `tesseract` on PATH.
# Windows example:
#   TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Ubuntu / WSL:
#   TESSERACT_CMD=/usr/bin/tesseract
# TESSERACT_CMD=

# Tesseract language data directory. Optional; if empty, Tesseract uses its default.
# TESSDATA_PREFIX=

# Default language(s) for OCR scripts (matches `tesseract -l ...`).
# X_MEDIA_OCR_LANG=chi_sim+eng
